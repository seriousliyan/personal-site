---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Li Yan - Personal Website">
    <nav class="navbar">
        <div class="nav-content">
            <a href="#home" class="logo">LY</a>
            <div class="nav-links">
                <a href="#about">About</a>
                <a href="#work">Work</a>
                <a href="#contact">Contact</a>
            </div>
        </div>
    </nav>

    <section id="home" class="hero">
        <div class="hero-content fade-in">
            <h1 class="hero-title">Hello, I'm <span class="highlight">Li Yan</span></h1>
            <p class="hero-subtitle">Creative Full Stack Engineer</p>
            <p class="hero-description">Specializing in AI-driven systems, LLM workflows, and scalable web platforms</p>
            <a href="#about" class="cta-button">Explore My Work</a>
        </div>
        <div class="scroll-indicator">
            <div class="mouse">
                <div class="wheel"></div>
            </div>
        </div>
    </section>

    <section id="about" class="section about-section">
        <div class="container">
            <div class="section-content scroll-fade">
                <h2 class="section-title">About Me</h2>
                <div class="about-grid">
                    <div class="about-text">
                        <p>Senior software engineer with experience building AI-driven products, LLM evaluation pipelines, and real-time voice systems that cut operational effort and improve reliability.</p>
                        <p>I build end-to-end web platforms and data-rich interfaces—from responsive React dashboards to backend services—translating complex data into clear, actionable experiences.</p>
                    </div>
                    <div class="skills">
                        <div class="skill-item scroll-fade-delay-1">
                            <div class="skill-icon">🤖</div>
                            <h3>AI & LLM Systems</h3>
                            <p>Voice agents, evaluation pipelines, and ML classification in production</p>
                        </div>
                        <div class="skill-item scroll-fade-delay-2">
                            <div class="skill-icon">🧩</div>
                            <h3>Full-Stack Product</h3>
                            <p>React/TypeScript interfaces backed by robust services and APIs</p>
                        </div>
                        <div class="skill-item scroll-fade-delay-3">
                            <div class="skill-icon">📊</div>
                            <h3>Data & Observability</h3>
                            <p>Dashboards, query tooling, and insights for complex system health</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="work" class="section work-section">
        <div class="container">
            <div class="section-content scroll-fade">
                <h2 class="section-title">Featured Work</h2>
                <div class="work-grid">
                    <div class="work-item scroll-fade-delay-1">
                        <div class="work-image">
                            <div class="placeholder-image">Voice AI</div>
                        </div>
                        <h3>Multi‑Agent Voice System</h3>
                        <p>Built outbound voice agents to verify hotel reservations, cutting FinOps labor by 60% with end‑to‑end call handling.</p>
                    </div>
                    <div class="work-item scroll-fade-delay-2">
                        <div class="work-image">
                            <div class="placeholder-image">LLM Quality</div>
                        </div>
                        <h3>LLM Evaluation Framework</h3>
                        <p>Designed a BrainTrust‑based eval pipeline to train, validate, and benchmark prompt/model updates against a golden dataset.</p>
                    </div>
                    <div class="work-item scroll-fade-delay-3">
                        <div class="work-image">
                            <div class="placeholder-image">APM AI</div>
                        </div>
                        <h3>APM AI Assistant</h3>
                        <p>Delivered a chat assistant and responsive dashboards that turned APM metrics into actionable insights for troubleshooting.</p>
                    </div>
                    <div class="work-item scroll-fade-delay-3">
                        <div class="work-image">
                            <div class="placeholder-image">Audio ML</div>
                        </div>
                        <h3>Voice Classifier</h3>
                        <p>Trained and deployed a WavLM-based model to detect human vs. automated voices with 95% accuracy and sub‑200ms latency.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="contact" class="section contact-section">
        <div class="container">
            <div class="section-content scroll-fade">
                <h2 class="section-title">Get In Touch</h2>
                <p class="contact-text">I'm always open to discussing new projects, creative ideas, or opportunities to be part of your vision.</p>
                <div class="contact-links">
                    <a href="mailto:seriousliyan@gmail.com" class="contact-link scroll-fade-delay-1">
                        <span class="contact-icon">✉️</span>
                        E-mail
                    </a>
                    <a href="/Li Yan – Full-Stack Resume.pdf" download target="_blank" class="contact-link scroll-fade-delay-2">
                        <span class="contact-icon">🔗</span>
                        Resume
                    </a>
                    <a href="https://linkedin.com/in/yourusername" target="_blank" class="contact-link scroll-fade-delay-3">
                        <span class="contact-icon">💼</span>
                        LinkedIn
                    </a>
                </div>
            </div>
        </div>
    </section>

    <footer class="footer">
        <p>&copy; 2026 Li Yan. Built with Astro.</p>
    </footer>
</Layout>
