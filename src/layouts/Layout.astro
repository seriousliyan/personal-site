---
import "../styles/style.css";
import animationScript from "../scripts/animation.js?url";

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <!-- Styles are bundled via Astro import -->
</head>
<body>
    <slot />
    <script type="module" src={animationScript}></script>
</body>
</html>
